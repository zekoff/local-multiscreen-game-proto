{
  "name": "bridge-crew",
  "version": "0.1.0",
  "description": "Prototype: co-located multi-device spaceship bridge crew game",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server-node.ts",
    "start": "tsx src/server-node.ts",
    "dev:cf": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.worker.json",
    "smoke": "node scripts/smoke.mjs",
    "smoke:cf": "node scripts/smoke-cf.mjs",
    "lab": "tsx scripts/mission-lab.ts",
    "checks": "tsx scripts/checks.ts"
  },
  "dependencies": {
    "express": "^4.19.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "@types/ws": "^8.5.10",
    "phaser": "^4.2.1",
    "playwright": "^1.61.1",
    "qrcode-generator": "^2.0.4",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "wrangler": "^4.110.0"
  }
}
